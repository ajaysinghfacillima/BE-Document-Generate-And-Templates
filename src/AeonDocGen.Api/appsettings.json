{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost"
    ]
  },
  "Storage": {
    "BrandingBasePath": "/data/branding",
    "DocumentBasePath": "/data/documents",
    "MaxRetryAttempts": 3,
    "RetryBaseDelayMilliseconds": 200
  },
  "BrandingUpload": {
    "AllowedLogoMimeTypes": [ "image/png", "image/jpeg", "image/svg+xml" ],
    "AllowedFontExtensions": [ ".ttf", ".otf", ".woff", ".woff2" ],
    "MaxLogoSizeBytes": 5242880,
    "MaxFontsZipSizeBytes": 20971520,
    "StorageBasePath": "/data/branding",
    "MalwareScanEnabled": true,
    "MalwareScanTimeoutSeconds": 30,
    "MalwareScanEndpoint": "",
    "IdempotencyRetentionHours": 24
  },
  "DocumentGeneration": {
    "StorageBasePath": "/data/documents",
    "MaxWatermarkLength": 200,
    "FooterVersionFormat": "v",
    "IdempotencyRetentionHours": 24,
    "RenderQueueWaitTimeoutSeconds": 60,
    "RenderQueuePollIntervalMilliseconds": 200,
    "EnableInlineRenderWorkerFallback": false,
    "RenderStoreMaxRetryAttempts": 3,
    "RetryBaseDelayMilliseconds": 500,
    "DefaultJobTimeoutSeconds": 120,
    "FailureAlertThreshold": 3,
    "FailureAlertWindowMinutes": 15,
    "RenderQueueBatchSize": 10
  },
  "Jwt": {
    "Issuer": "AeonDocGen",
    "Audience": "AeonDocGen.Api",
    "SigningKey": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  }
}
